{
  "name": "@jsfsi-core/template-authenticated-dashboard",
  "version": "2.0.0",
  "scripts": {
    "add:shadcn": "sh -c 'npx shadcn add \"$1\" --yes && if [ -d src/ui/components/ui ]; then mv src/ui/components/ui/* src/ui/components/ 2>/dev/null; rmdir src/ui/components/ui 2>/dev/null; fi' --",
    "build": "npm run lint && tsc && vite build",
    "clean": "rm -rf dist && rm -rf coverage && rm -rf node_modules",
    "deploy:production": "npm run build && gsutil -m rsync -d -r dist/ gs://template-authenticated-dashboard.jsfsi.com && gsutil -m setmeta -h \"Cache-Control:no-cache, max-age=0\" gs://template-authenticated-dashboard.jsfsi.com/index.html",
    "dev": "vite",
    "format": "biome format --write src",
    "lint": "biome check --write src",
    "lint:fix": "biome check --write src",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@jsfsi-core/ts-crossplatform": "file:../ts-crossplatform",
    "@jsfsi-core/ts-react": "file:../ts-react",
    "@radix-ui/react-avatar": "1.2.2",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-tooltip": "1.2.12",
    "date-fns": "4.4.0",
    "dequal": "2.0.3",
    "firebase": "12.16.0",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "8.2.1",
    "inversify": "8.1.3",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-i18next": "17.0.9",
    "react-router-dom": "7.18.1",
    "reflect-metadata": "0.2.2",
    "shadcn": "4.13.0",
    "sonner": "2.0.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/testing-library__dom": "7.5.0",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
"jsdom": "29.1.1",
    "lucide-react": "1.24.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "vite": "8.1.4",
    "vite-plugin-compression": "0.5.1",
    "vitest": "4.1.10"
  }
}
