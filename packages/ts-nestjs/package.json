{
  "name": "@jsfsi-core/ts-nestjs",
  "version": "2.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsfsi/jsfsi-core-typescript.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run lint && tsc --noEmit && vite build",
    "build:watch": "tsc && (tsc --watch & vite build --watch)",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf coverage",
    "format": "biome format --write src",
    "lint": "biome check --write src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jsfsi-core/ts-crossplatform": "file:../ts-crossplatform",
    "@jsfsi-core/ts-nodejs": "file:../ts-nodejs",
    "@nestjs/cli": "11.0.24",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/typeorm": "11.0.3",
    "body-parser": "2.3.0",
    "express": "5.2.1",
    "reflect-metadata": "0.2.2",
    "typeorm": "1.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@swc/core": "1.15.43",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.10",
    "supertest": "7.2.2",
    "ts-node": "10.9.2",
    "unplugin-swc": "1.5.9",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.10"
  },
  "peerDependenciesMeta": {
    "body-parser": {
      "optional": false
    },
    "express": {
      "optional": false
    }
  },
  "engines": {
    "node": "26.5.0",
    "npm": "11.17.0"
  }
}
