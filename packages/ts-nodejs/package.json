{
  "name": "@jsfsi-core/ts-nodejs",
  "version": "2.0.1",
  "description": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsfsi/jsfsi-core-typescript.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run lint && tsc --noEmit && vite build",
    "build:watch": "tsc && (tsc --watch & vite build --watch)",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf coverage",
    "format": "biome format --write src",
    "lint": "biome check --write src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jsfsi-core/ts-crossplatform": "file:../ts-crossplatform",
    "dotenv": "17.4.2",
    "fast-safe-stringify": "2.1.1",
    "typeorm": "1.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vitest": "4.1.10"
  }
}
