{
  "name": "@jsfsi-core/ts-react",
  "version": "2.0.2",
  "description": "React utilities for building applications with hexagonal architecture",
  "repository": {
    "type": "git",
    "url": "https://github.com/jsfsi/jsfsi-core-typescript.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run lint && tsc --noEmit && vite build",
    "build:watch": "tsc && (tsc --watch & vite build --watch)",
    "clean": "rm -rf dist && rm -rf node_modules && rm -rf coverage",
    "format": "biome format --write src",
    "lint": "biome check --write src",
    "lint:fix": "biome check --write src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jsfsi-core/ts-crossplatform": "file:../ts-crossplatform"
  },
  "peerDependencies": {
    "dequal": ">=2",
    "firebase": ">=12",
    "inversify": ">=7",
    "react": ">=18",
    "react-dom": ">=18",
    "react-hook-form": ">=7",
    "react-router-dom": ">=6"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@hookform/resolvers": "5.4.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "dequal": "2.0.3",
    "firebase": "12.16.0",
    "inversify": "8.1.3",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "react-router-dom": "7.18.1",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "zod": "4.4.3",
    "vitest": "4.1.10"
  }
}
